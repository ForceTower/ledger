# Postgres
POSTGRES_USER=ledger
POSTGRES_PASSWORD=change-me
POSTGRES_DB=ledger

# Where Postgres data is persisted on the host (Mac mini / Raspberry Pi).
LEDGER_DATA_DIR=./data

# The single bearer token every client sends. Generate: openssl rand -hex 32
API_TOKEN=

# Host port the API listens on (Cloudflare Tunnel points here).
API_PORT=48080

# Override only if the SEFAZ host changes.
SEFAZ_BASE_URL=http://nfe.sefaz.ba.gov.br/servicos/nfce/modulos/geral/

# Firebase Cloud Messaging (push to the iOS app). Optional — leave blank to disable push.
# base64 -i service-account.json | tr -d '\n'
FIREBASE_SERVICE_ACCOUNT_BASE64=

# OpenTelemetry logs (optional). Leave the endpoint blank to log only to stdout.
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_HEADERS=
OTEL_SERVICE_NAME=ledger-api
