{
  "name": "@ledger/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "start": "bun run src/index.ts",
    "migrate": "bun run scripts/migrate.ts up",
    "migrate:down": "bun run scripts/migrate.ts down-latest",
    "migrate:status": "bun run scripts/migrate.ts status",
    "db:codegen": "kysely-codegen",
    "import:legacy": "bun run scripts/import-legacy.ts",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "lint": "oxlint src",
    "lint:fix": "oxlint --fix src"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.111.0",
    "@hono/zod-validator": "^0.7.6",
    "@ledger/nfce": "workspace:*",
    "@ledger/shared-types": "workspace:*",
    "@loglayer/transport-opentelemetry": "^4.0.2",
    "@loglayer/transport-pino": "^3.0.2",
    "@opentelemetry/api-logs": "^0.215.0",
    "@opentelemetry/exporter-logs-otlp-http": "^0.215.0",
    "@opentelemetry/resources": "^2.7.0",
    "@opentelemetry/sdk-logs": "^0.215.0",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "firebase-admin": "^13.8.0",
    "hono": "^4.12.14",
    "http-status": "^2.1.0",
    "ioredis": "^5.10.1",
    "kysely": "^0.28.16",
    "loglayer": "^9.1.0",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "serialize-error": "^13.0.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "^1.3.12",
    "@types/pg": "^8.20.0",
    "kysely-codegen": "^0.18.5",
    "typescript": "^5.9.3"
  }
}
