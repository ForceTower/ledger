# Server
PORT=3000
NODE_ENV=development

# Database
DATABASE_URL=postgres://ledger:ledger@localhost:5433/ledger

# Redis — caching and the scan write-lock.
REDIS_URL=redis://localhost:6380

# Auth — the single bearer token every client must send. Generate a long random one:
#   openssl rand -hex 32
API_TOKEN=

# SEFAZ-BA NFC-e consultation host (used by @ledger/nfce). Override only if it changes.
SEFAZ_BASE_URL=http://nfe.sefaz.ba.gov.br/servicos/nfce/modulos/geral/

# Firebase Cloud Messaging — push notifications to the iOS app. Optional: leave unset to disable push.
# Service account JSON, base64-encoded:  base64 -i service-account.json | tr -d '\n'
FIREBASE_SERVICE_ACCOUNT_BASE64=

# OpenTelemetry logs — optional. Leave unset to log only to stdout. Point at an OTLP-compatible
# backend; the SDK appends /v1/logs automatically.
OTEL_EXPORTER_OTLP_ENDPOINT=
# Auth headers for the OTLP endpoint, comma-separated key=value pairs.
OTEL_EXPORTER_OTLP_HEADERS=
OTEL_SERVICE_NAME=ledger-api

# AI photo scan (POST /scan/photo). Two backends, chosen by whether ANTHROPIC_API_KEY is set:
#  - Set ANTHROPIC_API_KEY: the Anthropic API is used (recommended). Also powers the future /ask assistant.
#  - Leave it unset: the Claude CLI (CLAUDE_BIN) is invoked on the host — it must be an installed,
#    authenticated claude binary.
# CLAUDE_MODEL applies to both backends (default claude-haiku-4-5 — cheap and accurate enough here).
# CLAUDE_PHOTO_PROMPT is the identification instruction only (blank = built-in default); the strict
# output format is always enforced server-side.
ANTHROPIC_API_KEY=
CLAUDE_BIN=claude
CLAUDE_MODEL=claude-haiku-4-5
CLAUDE_PHOTO_PROMPT=
CLAUDE_TIMEOUT_MS=60000
